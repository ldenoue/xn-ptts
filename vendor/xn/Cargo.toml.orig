[package]
name = "xn"
version.workspace = true
edition = "2024"
description.workspace = true
repository.workspace = true
keywords.workspace = true
categories.workspace = true
license.workspace = true

[dependencies]
byteorder = { workspace = true }
cudarc = { workspace = true, optional = true }
gemm = { workspace = true }
half = { workspace = true }
kaudio = { workspace = true, optional = true }
libc = { workspace = true, optional = true }
libm = { workspace = true }
memmap2 = { workspace = true }
num-traits = { workspace = true }
num_cpus = { workspace = true }
rand = { workspace = true, features = ["thread_rng"] }
rand_distr = { workspace = true }
rayon = { workspace = true }
safetensors = { workspace = true }
thiserror = { workspace = true }
tracing = { workspace = true }
tracing-subscriber = { workspace = true }
yoke = { workspace = true }

[dev-dependencies]
anyhow = { workspace = true }
paste = { workspace = true }
rand = { workspace = true }
serde_json = { workspace = true }

# Example-only dev-deps. They pull in C/socket code that doesn't build on
# `wasm32-wasip1`, so gate them to non-wasm targets — tests don't use them.
[target.'cfg(not(target_arch = "wasm32"))'.dev-dependencies]
clap = { workspace = true }
hf-hub = { workspace = true }
tokenizers = { workspace = true }
tracing-chrome = { workspace = true }

[build-dependencies]
bindgen_cuda = { workspace = true, optional = true }

[features]
default = []
accelerate = ["dep:libc"]
audio = ["dep:kaudio"]
cuda = ["dep:cudarc", "dep:bindgen_cuda"]

[[example]]
name = "mimi"
required-features = ["audio"]

[[example]]
name = "demucs"
required-features = ["audio"]

[[example]]
name = "basic_cuda"
required-features = ["cuda"]

[[example]]
name = "cuda_benchmarks"
required-features = ["cuda"]

[[example]]
name = "cuda_thread_test"
required-features = ["cuda"]
